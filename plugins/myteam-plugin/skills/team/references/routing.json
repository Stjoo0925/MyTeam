{
  "executionModes": {
    "light": {
      "runIf": [
        "simple_request",
        "single_file_change",
        "translation",
        "ui_text_change",
        "minor_refactor",
        "small_frontend_fix"
      ],
      "skipIf": [
        "authentication_change",
        "database_schema_change",
        "production_incident",
        "large_refactor",
        "new_feature_architecture",
        "multi_agent_conflict_expected"
      ],
      "requiresPM": false,
      "requiresCTO": false,
      "maxSpecialists": 1,
      "tokenBudget": "low"
    },
    "standard": {
      "runIf": [
        "medium_complexity",
        "api_modification",
        "frontend_backend_coordination",
        "small_feature_implementation",
        "focused_bug_fix"
      ],
      "requiresPM": true,
      "requiresCTO": false,
      "maxSpecialists": 2,
      "tokenBudget": "medium"
    },
    "deep": {
      "runIf": [
        "authentication_change",
        "authorization_change",
        "database_schema_change",
        "production_incident",
        "large_refactor",
        "new_feature_architecture",
        "security_sensitive",
        "high_risk_change"
      ],
      "requiresPM": true,
      "requiresCTO": true,
      "maxSpecialists": 6,
      "tokenBudget": "high"
    }
  },
  "router": {
    "keywords": [
      "route",
      "router",
      "execution mode",
      "light mode",
      "standard mode",
      "deep mode",
      "token efficiency",
      "token minimization",
      "agent selection",
      "conditional execution"
    ]
  },
  "cto": {
    "keywords": [
      "cto",
      "orchestration",
      "workflow",
      "review loop",
      "agent order",
      "routing",
      "context trimming",
      "token budget",
      "retry policy",
      "conflict merge",
      "output contract",
      "tool dependency",
      "mcp dependency",
      "deployment version"
    ],
    "runIf": [
      "deep_mode",
      "multi_agent_conflict_expected",
      "integration_risk",
      "retry_escalation_required",
      "validation_routing_required"
    ],
    "skipIf": [
      "light_mode",
      "single_specialist_sufficient",
      "ui_only_change",
      "translation_only"
    ]
  },
  "frontend": {
