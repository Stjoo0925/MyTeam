{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/myteam/agent-result.schema.json",
  "title": "AgentResult",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "success"
          }
        }
      },
      "then": {
        "properties": {
          "contractCompliance": {
            "properties": {
              "valid": {
                "const": true
              }
            }
          },
          "confidence": {
            "minimum": 0.7
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification": {
            "properties": {
              "result": {
                "const": "failed"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "status": {
            "enum": ["failed", "blocked", "needs_clarification"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "contractOfficerDecision": {
            "properties": {
              "decision": {
                "const": "accept"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "contractCompliance": {
            "properties": {
              "valid": {
                "const": true
              }
            }
          }
        }
      }
    }
  ],
  "required": [
    "agent",
    "role",
    "assignmentId",
    "status",
    "summary",
    "ownedScope",
    "forbiddenScope",
    "filesToModify",
    "risks",
    "requiresOtherAgents",
    "verification",
    "contractCompliance",
    "accountabilityScoreDelta",
    "contractOfficerDecision",
    "confidence"
  ],
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": [
        "pm",
        "contract_officer",
        "cto",
        "frontend",
        "backend",
        "architect",
        "domain",
        "qa",
        "security",
        "coder",
        "integrator",
        "skill_evaluator"
      ]
    },
    "assignmentId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "blocked", "failed", "needs_clarification"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "ownedScope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenScope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "filesToModify": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiresOtherAgents": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "pm",
          "contract_officer",
          "cto",
          "frontend",
          "backend",
          "architect",
          "domain",
          "qa",
          "security",
          "coder",
          "integrator",
          "skill_evaluator"
        ]
      },
      "uniqueItems": true
    },
    "verification": {
      "type": "object",
      "required": ["performed", "commands", "result", "remainingGaps"],
      "properties": {
        "performed": {
          "type": "boolean"
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "result": {
          "type": "string",
          "enum": ["passed", "failed", "not_run", "blocked"]
        },
        "remainingGaps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "contractCompliance": {
      "type": "object",
      "required": ["valid", "missingFields", "normalizations"],
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "missingFields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "normalizations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "accountabilityScoreDelta": {
      "type": "integer",
      "minimum": -2,
      "maximum": 2,
      "description": "Internal routing signal assigned by Contract Officer. Positive values represent contract-quality confidence; negative values represent failed or weak contract performance."
    },
    "contractOfficerDecision": {
      "type": "object",
      "required": ["decision", "reason"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "accept",
            "retry",
            "revise",
            "escalate_to_cto",
            "ask_user",
            "reject_output"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
