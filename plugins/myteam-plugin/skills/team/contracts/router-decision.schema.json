{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/myteam/router-decision.schema.json",
  "title": "RouterDecision",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "light"
          }
        }
      },
      "then": {
        "properties": {
          "requiresPM": {
            "const": false
          },
          "requiresCTO": {
            "const": false
          },
          "tokenBudget": {
            "const": "low"
          },
          "delegation": {
            "properties": {
              "maxSubAgents": {
                "maximum": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "standard"
          }
        }
      },
      "then": {
        "properties": {
          "requiresPM": {
            "const": true
          },
          "requiresCTO": {
            "const": false
          },
          "tokenBudget": {
            "enum": ["low", "medium"]
          },
          "delegation": {
            "properties": {
              "maxSubAgents": {
                "maximum": 2
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "deep"
          }
        }
      },
      "then": {
        "properties": {
          "requiresPM": {
            "const": true
          },
          "requiresCTO": {
            "const": true
          },
          "tokenBudget": {
            "enum": ["medium", "high"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation": {
            "properties": {
              "shouldDelegate": {
                "const": false
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "delegation": {
            "properties": {
              "allowedAgentType": {
                "const": "none"
              },
              "maxSubAgents": {
                "const": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation": {
            "properties": {
              "shouldDelegate": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "delegation": {
            "properties": {
              "allowedAgentType": {
                "enum": ["explorer", "worker", "explorer_and_worker"]
              },
              "maxSubAgents": {
                "minimum": 1
              }
            }
          }
        }
      }
    }
  ],
  "required": [
    "mode",
    "taskType",
    "requiredAgents",
    "requiresPM",
    "requiresCTO",
    "requiresQA",
    "requiresSecurity",
    "tokenBudget",
    "executionStrength",
    "delegation",
    "overuseGuard",
    "reason"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["light", "standard", "deep"]
    },
    "taskType": {
      "type": "string",
      "minLength": 1
    },
    "requiredAgents": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "router",
          "pm",
          "cto",
          "frontend",
          "backend",
          "architect",
          "domain",
          "qa",
          "security",
          "coder",
          "integrator",
          "skill_evaluator"
        ]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "requiresPM": {
      "type": "boolean"
    },
    "requiresCTO": {
      "type": "boolean"
    },
    "requiresQA": {
      "type": "boolean"
    },
    "requiresSecurity": {
      "type": "boolean"
    },
    "tokenBudget": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "executionStrength": {
      "type": "string",
      "enum": ["minimal", "normal", "strong"],
      "description": "How forcefully the selected workflow should execute. Strong means required routing, contracts, validation, and eligible delegation must be applied, while still respecting overuse limits."
    },
    "delegation": {
      "type": "object",
      "required": [
        "shouldDelegate",
        "allowedAgentType",
        "maxSubAgents",
        "reason",
        "skipReason"
      ],
      "properties": {
        "shouldDelegate": {
          "type": "boolean"
        },
        "allowedAgentType": {
          "type": "string",
          "enum": ["none", "explorer", "worker", "explorer_and_worker"]
        },
        "maxSubAgents": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "skipReason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "overuseGuard": {
      "type": "object",
      "required": [
        "singleAgentSufficient",
        "excludedAgents",
        "exclusionReasons",
        "scopeLimit"
      ],
      "properties": {
        "singleAgentSufficient": {
          "type": "boolean"
        },
        "excludedAgents": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pm",
              "cto",
              "frontend",
              "backend",
              "architect",
              "domain",
              "qa",
              "security",
              "coder",
              "integrator",
              "skill_evaluator"
            ]
          },
          "uniqueItems": true
        },
        "exclusionReasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "scopeLimit": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
