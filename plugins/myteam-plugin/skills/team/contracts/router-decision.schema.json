{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/myteam/router-decision.schema.json",
  "title": "RouterDecision",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "light"
          }
        }
      },
      "then": {
        "properties": {
          "requiresPM": {
            "const": false
          },
          "requiresCTO": {
            "const": false
          },
          "tokenBudget": {
            "const": "low"
          },
          "delegation": {
            "properties": {
              "maxSubAgents": {
                "maximum": 1
              }
            }
          },
          "contractOfficerMode": {
            "enum": ["none", "assign_only", "validate_only", "assign_and_validate"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "standard"
          }
        }
      },
      "then": {
        "properties": {
          "requiresPM": {
            "const": true
          },
          "requiresCTO": {
            "const": false
          },
          "tokenBudget": {
            "enum": ["low", "medium"]
          },
          "delegation": {
            "properties": {
              "maxSubAgents": {
                "maximum": 2
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "deep"
          }
        }
      },
      "then": {
        "properties": {
          "requiresPM": {
            "const": true
          },
          "requiresCTO": {
            "const": true
          },
          "tokenBudget": {
            "enum": ["medium", "high"]
          },
          "requiresContractOfficer": {
            "const": true
          },
          "contractOfficerMode": {
            "const": "assign_and_validate"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "deep"
          },
          "delegation": {
            "properties": {
              "runtimeSubAgentsAvailable": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "delegation": {
            "properties": {
              "shouldDelegate": {
                "const": true
              },
              "maxSubAgents": {
                "minimum": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation": {
            "properties": {
              "shouldDelegate": {
                "const": false
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "delegation": {
            "properties": {
              "allowedAgentType": {
                "const": "none"
              },
              "maxSubAgents": {
                "const": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation": {
            "properties": {
              "shouldDelegate": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "delegation": {
            "properties": {
              "allowedAgentType": {
                "enum": ["explorer", "worker", "explorer_and_worker"]
              },
              "maxSubAgents": {
                "minimum": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requiresContractOfficer": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "contractOfficerMode": {
            "const": "none"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requiresContractOfficer": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "contractOfficerMode": {
            "enum": ["assign_only", "validate_only", "assign_and_validate"]
          }
        }
      }
    }
  ],
  "required": [
    "mode",
    "taskType",
    "requiredAgents",
    "requiresContractOfficer",
    "contractOfficerMode",
    "requiresPM",
    "requiresCTO",
    "requiresQA",
    "requiresSecurity",
    "tokenBudget",
    "executionStrength",
    "delegation",
    "overuseGuard",
    "reason"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["light", "standard", "deep"]
    },
    "taskType": {
      "type": "string",
      "minLength": 1
    },
    "requiredAgents": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "router",
          "contract_officer",
          "pm",
          "cto",
          "frontend",
          "backend",
          "architect",
          "domain",
          "qa",
          "security",
          "coder",
          "integrator",
          "skill_evaluator"
        ]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "requiresPM": {
      "type": "boolean"
    },
    "requiresContractOfficer": {
      "type": "boolean"
    },
    "contractOfficerMode": {
      "type": "string",
      "enum": ["none", "assign_only", "validate_only", "assign_and_validate"],
      "description": "How Contract Officer participates in this workflow. Use none only for simple final-answer work with no delegation and low contract risk."
    },
    "requiresCTO": {
      "type": "boolean"
    },
    "requiresQA": {
      "type": "boolean"
    },
    "requiresSecurity": {
      "type": "boolean"
    },
    "tokenBudget": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "executionStrength": {
      "type": "string",
      "enum": ["minimal", "normal", "strong"],
      "description": "How forcefully the selected workflow should execute. Strong means required routing, contracts, validation, and eligible delegation must be applied, while still respecting overuse limits."
    },
    "executionPattern": {
      "type": "string",
      "enum": ["direct_response", "agent_loop", "wide_parallel", "scheduled", "monitoring"],
      "description": "Optional agentic execution pattern. Use direct_response for answer-only work; use agent_loop, wide_parallel, scheduled, or monitoring when the task requires action, state, automation, or synthesis."
    },
    "executionSurface": {
      "type": "string",
      "enum": ["none", "local_workspace", "local_browser", "cloud_browser", "external_connector", "automation", "mixed"],
      "description": "Optional execution surface required by the task. Use none for answer-only work."
    },
    "requiresApprovalGate": {
      "type": "boolean",
      "description": "Whether the task requires explicit approval before browser, connector, authenticated, destructive, purchase, posting, messaging, or cross-workspace action."
    },
    "requiresPersistentState": {
      "type": "boolean",
      "description": "Whether task state or a checkpoint should be preserved for resumability."
    },
    "requiresArtifactManifest": {
      "type": "boolean",
      "description": "Whether created or modified deliverables must be listed in an artifact manifest."
    },
    "requiresScheduling": {
      "type": "boolean",
      "description": "Whether the task should route to delayed, recurring, heartbeat, or monitoring automation when available."
    },
    "requiresWideParallelism": {
      "type": "boolean",
      "description": "Whether the task has enough independent repeated items to justify wide parallel or batched processing."
    },
    "delegation": {
      "type": "object",
      "required": [
        "shouldDelegate",
        "allowedAgentType",
        "maxSubAgents",
        "reason",
        "skipReason",
        "runtimeSubAgentsAvailable",
        "distinctOwnershipReason",
        "blockingReasonIfNotDelegated"
      ],
      "properties": {
        "shouldDelegate": {
          "type": "boolean"
        },
        "allowedAgentType": {
          "type": "string",
          "enum": ["none", "explorer", "worker", "explorer_and_worker"]
        },
        "maxSubAgents": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "skipReason": {
          "type": "string",
          "minLength": 1
        },
        "runtimeSubAgentsAvailable": {
          "type": "boolean",
          "description": "Whether the current runtime provides usable explorer or worker sub-agents for this request."
        },
        "distinctOwnershipReason": {
          "type": "string",
          "minLength": 1,
          "description": "Why delegated ownership is distinct from the team lead and other agents, or why no delegation is valid."
        },
        "blockingReasonIfNotDelegated": {
          "type": "string",
          "minLength": 1,
          "description": "Required when shouldDelegate is false for non-trivial work; state simple final-answer work, unclear scope, unavailable agents, or higher-priority policy."
        }
      },
      "additionalProperties": false
    },
    "overuseGuard": {
      "type": "object",
      "required": [
        "singleAgentSufficient",
        "excludedAgents",
        "exclusionReasons",
        "scopeLimit"
      ],
      "properties": {
        "singleAgentSufficient": {
          "type": "boolean"
        },
        "excludedAgents": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pm",
              "contract_officer",
              "cto",
              "frontend",
              "backend",
              "architect",
              "domain",
              "qa",
              "security",
              "coder",
              "integrator",
              "skill_evaluator"
            ]
          },
          "uniqueItems": true
        },
        "exclusionReasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "scopeLimit": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
